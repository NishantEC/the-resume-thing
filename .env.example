# Prisma — SQLite for local dev; swap for a Postgres URL in prod.
DATABASE_URL="file:./dev.db"

# Better Auth — generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"

# GitHub OAuth app — https://github.com/settings/developers
# Authorization callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# LLM for resume synthesis — provider: "google" (Gemini, default) or "openai"
LLM_PROVIDER="google"
# Optional model override (defaults: google=gemini-3.5-flash, openai=gpt-4o-mini)
LLM_MODEL=""
# Set the key for your chosen provider (only the selected one is required):
GOOGLE_GENERATIVE_AI_API_KEY="" # https://aistudio.google.com/apikey
OPENAI_API_KEY=""               # https://platform.openai.com/api-keys
